rules_version = '2';
// Deployed via `firebase deploy --only firestore:rules` (or paste into
// Firebase Console → Firestore Database → Rules → Publish).
//
// Family login required for the grocery list itself. Setup (already done
// as of 2026-07-04):
//   1. Console → Authentication → Sign-in method → enable Email/Password
//   2. Console → Authentication → Users → Add user
//      (email = FAMILY_EMAIL from index.html, password = the app's access code)
//   3. That user's UID is baked in below as FAMILY_UID.
//
// Locking to the UID matters: "request.auth != null" alone is not enough,
// because anyone can create their own account against a public Firebase config.
//
// EXCEPTION: `recipes` and `mealPlans` are public read (no auth) so the
// kitchen-display chalkboard widget (?widget=1) works on a screen that never
// logs in. Writes to those collections still require the family login.
// `items` (the actual shopping list) and `config` stay fully private.
service cloud.firestore {
  match /databases/{database}/documents {
    function isFamily() {
      return request.auth != null && request.auth.uid == '2Cuht8KY3mQTznkgf5roRmZrkzt1';
    }

    match /items/{itemId} {
      allow read, write: if isFamily();
    }
    match /recipes/{recipeId} {
      allow read: if true;
      allow write: if isFamily();
    }
    match /mealPlans/{planId} {
      allow read: if true;
      allow write: if isFamily();
    }
    match /config/{docId} {
      allow read, write: if isFamily();
    }
  }
}
