rules_version = '2';
// Paste into Firebase Console → Firestore Database → Rules → Publish.
//
// Requires the shared family account to be signed in. Setup:
//   1. Console → Authentication → Sign-in method → enable Email/Password
//   2. Console → Authentication → Users → Add user
//      (email = FAMILY_EMAIL from index.html, password = your new access code, 6+ chars)
//   3. Copy that user's UID from the Users table and replace FAMILY_UID below.
//
// Locking to the UID matters: "request.auth != null" alone is not enough,
// because anyone can create their own account against a public Firebase config.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == '2Cuht8KY3mQTznkgf5roRmZrkzt1';
    }
  }
}
